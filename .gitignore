.DS_Store
*.bak
*.log
node_modules/
dist/
.env
.env.*
.claude/projects/

# Dogfooding — agentboard runs against its own repo to generate real usage
# data. Track the .platform/ work pack so streams, checkpoints, and memory
# survive across machines; keep only volatile runtime artifacts local-only.
.codex/
.claude/settings.json
.claude/settings.json.agentboard-backup-*




# agentboard:runtime-begin
.platform/events.jsonl
.platform/events-*.jsonl
.platform/events.jsonl.archive-*
.platform/.daemon-port
.platform/.file-change-state.lock
.platform/.file-change-state.lock.d/
.platform/.file-change-state.tsv
.platform/.file-locks.json
.platform/.session-streams.tsv
.platform/.watch.pid
.platform/.watch/
# agentboard:runtime-end
