#!/usr/bin/env node
'use strict';

const { spawn } = require('child_process');
const path = require('path');

const bashCli = path.join(__dirname, '..', 'bin', 'agentboard');
const args = process.argv.slice(2);

const child = spawn(bashCli, args, { stdio: 'inherit' });

child.on('error', (err) => {
  process.stderr.write(`agentboard: failed to start bash CLI: ${err.message}\n`);
  process.exit(1);
});

child.on('close', (code) => {
  process.exit(code ?? 1);
});
